# Dokumented Configuration
# All configuration must be set in this file. API keys are NEVER stored in the database.
# Copy this file to .env and fill in your values.

# =============================================================================
# API KEYS (Required)
# =============================================================================
# Get your keys from:
# - Anthropic: https://console.anthropic.com/
# - Mercury/Inception Labs: https://platform.inceptionlabs.ai/

ANTHROPIC_API_KEY=sk-ant-your-key-here
MERCURY_API_KEY=your-mercury-key-here
MERCURY_BASE_URL=https://api.inceptionlabs.ai/v1

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=sqlite:///./dokumented.db

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
UPLOAD_FOLDER=./documents
MAX_RETRIES=3
CONFIDENCE_THRESHOLD=0.75
