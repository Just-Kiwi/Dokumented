# Dokumented Configuration
# All configuration must be set in this file. API keys are NEVER stored in the database.
# Copy this file to .env and fill in your values.

# =============================================================================
# API KEYS (Required)
# =============================================================================
# Get your OpenRouter API key from: https://openrouter.ai/
# Models used:
#   - LLM: anthropic/claude-3.5-sonnet (fingerprinting/script generation)
#   - dLLM: inception-ai/Mercury-2 (field validation)

OPENROUTER_API_KEY=your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=sqlite:///./dokumented.db

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
UPLOAD_FOLDER=./documents
MAX_RETRIES=3
CONFIDENCE_THRESHOLD=0.75
